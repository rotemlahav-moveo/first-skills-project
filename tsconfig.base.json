{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shared/auth-contracts": ["libs/shared/auth-contracts/src/index.ts"],
      "@shared/auth-domain": ["libs/shared/auth-domain/src/index.ts"],
      "@shared/form-system": ["libs/shared/form-system/src/index.ts"],
      "@shared/products-contracts": ["libs/shared/products-contracts/src/index.ts"],
      "@shared/favorites-contracts": ["libs/shared/favorites-contracts/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
