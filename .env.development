# Used by `apps/front/vite.config.mts` when running `nx serve front`.
# Proxies browser requests from /api → your local Nest app.
# 127.0.0.1 is "localhost" (this computer only, not your EC2 prod server).
# Port must match PORT= when you run the backend (you use 3001).
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3001
